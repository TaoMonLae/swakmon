generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ListingStatus {
  PENDING
  ACTIVE
  SOLD
  RENTED
  ARCHIVED
}

enum ListingTier {
  BASIC
  FEATURED
  PREMIUM
}

enum PriceType {
  FIXED
  MONTHLY
  WEEKLY
  NEGOTIABLE
}

enum CommissionType {
  NONE
  PERCENTAGE
  FIXED_MMK
}

enum DiscountType {
  PERCENTAGE
  FIXED_MMK
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      String   @default("admin")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Category {
  id       Int       @id @default(autoincrement())
  name     String
  slug     String    @unique
  icon     String
  order    Int       @default(0)
  listings Listing[]
}

model State {
  id        Int        @id @default(autoincrement())
  name      String
  slug      String     @unique
  townships Township[]
  listings  Listing[]
}

model Township {
  id       Int       @id @default(autoincrement())
  name     String
  stateId  Int
  state    State     @relation(fields: [stateId], references: [id])
  listings Listing[]
}

model Listing {
  id                Int             @id @default(autoincrement())
  listingRef        String          @unique
  title             String
  description       String          @db.Text
  price             Int?
  priceLabel        String?
  priceType         PriceType       @default(FIXED)
  status            ListingStatus   @default(PENDING)
  tier              ListingTier     @default(BASIC)
  tierOverridePrice Int?
  tierDiscountPct   Int?
  isFreeUntilSold   Boolean         @default(false)
  commissionType    CommissionType?
  commissionValue   Float?
  contactPhone      String?
  contactViber      Boolean         @default(true)
  contactWhatsApp   Boolean         @default(true)
  contactFacebook   String?
  adminNotes        String?         @db.Text
  // Ordered list of image objects: { url: string, publicId: string }
  images            Json            @default("[]")
  viewCount         Int             @default(0)


  categoryId Int
  category   Category @relation(fields: [categoryId], references: [id])
  stateId    Int
  state      State    @relation(fields: [stateId], references: [id])
  townshipId Int
  township   Township @relation(fields: [townshipId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, stateId])
  @@index([status, createdAt])
  @@index([categoryId])
  @@index([tier])
}

model Promotion {
  id                String       @id @default(cuid())
  name              String
  discountType      DiscountType
  discountValue     Float
  appliesToTier     String       @default("all")
  appliesToCategory String       @default("all")
  appliesToState    String       @default("all")
  validFrom         DateTime
  validUntil        DateTime
  isActive          Boolean      @default(true)
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  @@index([isActive, validFrom, validUntil])
}

// Single-row table (id = "global") holding admin-editable pricing/tier config.
model PricingConfig {
  id                   String   @id @default("global")
  tiers                Json
  freeUntilSoldDefault Boolean  @default(false)
  defaultCommission    Float    @default(3)
  updatedAt            DateTime @updatedAt
}
